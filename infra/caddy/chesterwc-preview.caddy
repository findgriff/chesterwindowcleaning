# chesterwc.dev.opspocket.com — was the staging preview for
# chesterwindowcleaner.co.uk; the real domain launched 2026-06-11 so
# this now just redirects (avoids a duplicate copy of the site in
# search engines).
chesterwc.dev.opspocket.com {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	redir https://chesterwindowcleaner.co.uk{uri} permanent
}
